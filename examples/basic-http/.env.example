WHATSAPP_MODE=sandbox

# Webhook security — required for receiving webhooks
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Sandbox mode variables
WHATSAPP_SANDBOX_PHONE_NUMBER_ID=1234567890
WHATSAPP_SANDBOX_ACCESS_TOKEN=your_sandbox_token
WHATSAPP_SANDBOX_TEST_RECIPIENTS=+15551234567

# Live mode variables (used when WHATSAPP_MODE=live)
WHATSAPP_LIVE_BUSINESS_ACCOUNT_ID=
WHATSAPP_LIVE_PHONE_NUMBER_ID=
WHATSAPP_LIVE_ACCESS_TOKEN=

PORT=3344
# Number of reverse proxy hops in front of this app (tunnel, load balancer, etc.)
# Uncomment and set when running behind a proxy (e.g. ngrok, Cloudflare Tunnel)
# TRUST_PROXY_HOPS=1

# TCP microservice client (used to call microservice example)
WHATSAPP_MICROSERVICE_HOST=127.0.0.1
WHATSAPP_MICROSERVICE_PORT=4455
